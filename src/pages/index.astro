---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Earth Bridge Alliance">
  <main class="flex min-h-screen flex-col items-center justify-center bg-gradient-to-br from-green-50 to-blue-50 p-8">
    <div class="max-w-2xl text-center">
      <h1 class="mb-4 text-5xl font-bold tracking-tight text-green-800">
        🌍 Earth Bridge Alliance
      </h1>
      <p class="mb-8 text-xl text-gray-600">
        Bridging communities for a sustainable future.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="https://docs.astro.build"
          target="_blank"
          class="rounded-lg bg-green-700 px-6 py-3 font-semibold text-white shadow transition hover:bg-green-800"
        >
          Astro Docs
        </a>
        <a
          href="https://tailwindcss.com"
          target="_blank"
          class="rounded-lg border border-green-700 px-6 py-3 font-semibold text-green-700 shadow transition hover:bg-green-50"
        >
          Tailwind CSS
        </a>
      </div>
    </div>
  </main>
</Layout>
