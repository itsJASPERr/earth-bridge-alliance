---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "We are creating a European NGO to support the living traditions, territorial rights, and self-determined projects of the Kamëntsá people in the Sibundoy Valley, Colombia." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,600&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --cream: #F3EDE0;
    --cream-light: #FAF8F3;
    --terracotta: #C4622D;
    --dark: #1C2010;
    --text: #2A2818;
    --text-muted: #5A5644;
    --footer-bg: #252D16;
    --footer-text: #C8C3AE;
    --border: rgba(44, 40, 24, 0.12);

    --font-serif: 'Cormorant Garamond', Georgia, serif;
    --font-sans: 'Inter', system-ui, sans-serif;

    --max-w: 1200px;
    --px: clamp(1.5rem, 4vw, 5rem);
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-sans);
    color: var(--text);
    background: var(--cream);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  img {
    display: block;
    max-width: 100%;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button {
    cursor: pointer;
    border: none;
    background: none;
    font: inherit;
  }

  .divider {
    display: flex;
    align-items: center;
    margin: 1.25rem 0;
    color: var(--terracotta);
  }

  .divider::before,
  .divider::after {
    content: '';
    display: block;
    width: 2.5rem;
    height: 1px;
    background: currentColor;
  }

  .divider-diamond {
    display: inline-block;
    width: 6px;
    height: 6px;
    background: currentColor;
    transform: rotate(45deg);
    margin: 0 8px;
    flex-shrink: 0;
  }

  .divider.centered {
    justify-content: center;
  }
</style>
